{
  "name": "@boris.barac/linkloom",
  "version": "0.1.5",
  "description": "Web scraping, Brave search, content extraction, and markdown conversion — in TypeScript/Bun",
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "homepage": "https://github.com/borisBarac/linkloom-agent-scraper",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borisBarac/linkloom-agent-scraper.git"
  },
  "bugs": {
    "url": "https://github.com/borisBarac/linkloom-agent-scraper/issues"
  },
  "license": "MIT",
  "keywords": [
    "scraping",
    "markdown",
    "pdf",
    "mcp",
    "bun",
    "cli",
    "web-scraping",
    "content-extraction"
  ],
  "engines": {
    "bun": ">=1"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.ts",
    "src/",
    "env.example",
    "README.md"
  ],
  "bin": {
    "linkloom": "src/cli.ts",
    "linkloom-mcp": "src/mcp.ts"
  },
  "scripts": {
    "test": "bun scripts/test-isolated.mjs",
    "test:aggregate": "bun test",
    "format": "bunx biome format --write",
    "lint": "bunx biome lint --write",
    "check": "bunx biome check --write",
    "type_check": "bunx tsc --noEmit",
    "start": "bun run index.ts",
    "cli": "bun run src/cli.ts",
    "mcp": "bun run src/cli.ts mcp",
    "setup:browser": "camoufox-js fetch && bun scripts/setup-camoufox.mjs",
    "browser:path": "camoufox-js path",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,md}": "bunx biome check --write"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "dependencies": {
    "@langchain/google-genai": "^2.1.28",
    "@langchain/openai": "^1.4.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "axios": "^1.15.2",
    "camoufox-js": "^0.10.2",
    "cheerio": "^1.2.0",
    "citty": "^0.2.2",
    "impit": "^0.14.2",
    "jsdom": "^29.0.2",
    "pdf.js-extract": "^1.0.1",
    "playwright": "^1.59.1",
    "turndown": "^7.2.4"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
