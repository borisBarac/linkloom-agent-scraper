{
  "name": "scraper_service",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.0.0",
    "@types/puppeteer": "^7.0.4",
    "@types/turndown": "^5.0.6",
    "grpc-tools": "^1.12.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "@langchain/google-genai": "^2.0.0",
    "@langchain/openai": "^1.1.3",
    "@mozilla/readability": "^0.6.0",
    "axios": "^1.13.2",
    "jsdom": "^27.2.0",
    "pdf.js-extract": "^0.2.1",
    "puppeteer": "^24.31.0",
    "puppeteer-extra": "^3.3.6",
    "turndown": "^7.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "format": "bunx biome format --write",
    "lint": "bunx biome lint --write",
    "check": "bunx biome check --write",
    "type_check": "bunx tsc --noEmit",
    "compile:proto": "grpc_tools_node_protoc --proto_path=../proto_files --js_out=import_style=commonjs,binary:./generated --grpc_out=grpc_js:./generated --plugin=protoc-gen-grpc=$(which grpc_tools_node_protoc_plugin) scraper.proto",

    "build": "bun run compile:proto",
    "start": "bun run index.ts"
  }
}
