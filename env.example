# Timeouts (ms)
PAGE_LOAD_TIMEOUT=10000
FRAME_TIMEOUT=5000
PDF_DOWNLOAD_TIMEOUT=30000

# API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=

# Proxy (optional, rotating proxy endpoint)
# Format: http://user:pass@host:port or socks5://host:port
PROXY_URL=

# Debug logging (optional)
# Set LINKLOOM_DEBUG=1 or DEBUG=linkloom to log non-fatal cleanup failures.
LINKLOOM_DEBUG=
